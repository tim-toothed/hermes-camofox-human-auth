+// POST /admin/display-mode - switch native headed/headless mode.
+// This is intentionally admin-key protected: it restarts the browser process.
+app.post('/admin/display-mode', async (req, res) => {
+  try {
+    const adminKey = req.headers['x-admin-key'];
+    const expectedKey = CONFIG.adminKey || process.env.CAMOFOX_ADMIN_KEY || '';
+    if (!expectedKey || !adminKey || !timingSafeCompare(adminKey, expectedKey)) {
+      return res.status(403).json({ error: 'Forbidden' });
+    }
+    const mode = String(req.body?.mode || '').toLowerCase();
+    if (!['headed', 'headless'].includes(mode)) {
+      return res.status(400).json({ error: 'mode must be headed or headless' });
+    }
+    nativeDisplayMode = mode;
+    await closeAllSessions('display_mode_switch', { clearDownloads: true, clearLocks: true });
+    await closeBrowserFully('display_mode_switch');
+    await ensureBrowser();
+    res.json({ ok: true, mode, browserRunning: true });
+  } catch (err) {
+    res.status(500).json({ ok: false, error: safeError(err) });
   }
