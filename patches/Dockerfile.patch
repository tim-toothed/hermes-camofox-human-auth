diff --git a/Dockerfile b/Dockerfile
index adb6a76..6b19526 100644
--- a/Dockerfile
+++ b/Dockerfile
@@ -30,6 +30,12 @@ RUN apt-get update && apt-get install -y \
     libgbm1 \
     # Xvfb virtual display -- runs Camoufox as if on a real desktop (better anti-detection)
     xvfb \
+    # VNC/noVNC interactive display for human login
+    x11vnc \
+    novnc \
+    python3-websockify \
+    net-tools \
+    procps \
     # Fonts
     fonts-liberation \
     fonts-noto-color-emoji \
@@ -65,6 +71,8 @@ COPY server.js ./
 COPY camofox.config.json ./
 COPY lib/ ./lib/
 COPY plugins/ ./plugins/
+# Normalize the watcher after Git's Windows line endings; /bin/sh requires consistent LF lines.
+RUN tr -d "$(printf '\\015')" < plugins/vnc/vnc-watcher.sh > /tmp/vnc-watcher.sh && mv /tmp/vnc-watcher.sh plugins/vnc/vnc-watcher.sh
 COPY scripts/ ./scripts/
 
 # Install default plugin dependencies (apt packages + post-install hooks)
@@ -81,6 +89,7 @@ CMD ["sh", "-c", "node --max-old-space-size=${MAX_OLD_SPACE_SIZE:-128} server.js
 # Usage: docker build --target with-plugins -t camofox-browser .
 FROM camofox-browser AS with-plugins
 COPY plugins/ ./plugins/
+RUN tr -d "$(printf '\\015')" < plugins/vnc/vnc-watcher.sh > /tmp/vnc-watcher.sh && mv /tmp/vnc-watcher.sh plugins/vnc/vnc-watcher.sh
 COPY camofox.config.json ./
 COPY scripts/install-plugin-deps.sh /tmp/install-plugin-deps.sh
 RUN /tmp/install-plugin-deps.sh && rm /tmp/install-plugin-deps.sh
